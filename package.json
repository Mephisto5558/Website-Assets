{
  "name": "website-assets",
  "version": "2.0.0",
  "description": "Assets for my website",
  "keywords": [
    "css",
    "js"
  ],
  "homepage": "https://github.com/Mephisto5558//Website-Assets#readme",
  "bugs": {
    "url": "https://github.com/Mephisto5558//Website-Assets/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mephisto5558/Website-Assets.git"
  },
  "license": "MIT",
  "author": "Mephisto5558",
  "type": "module",
  "main": "index.js",
  "types": "globals.d.ts",
  "scripts": {
    "build": "npm-run-all --parallel build:**",
    "prebuild:css": "node -e \"require('node:fs').rmSync('min/css', { recursive: true, force: true });\"",
    "build:css": "esbuild css/**/*.css --bundle --minify --outdir=min/css",
    "prebuild:js": "node -e \"require('node:fs').rmSync('min/js', { recursive: true, force: true });\"",
    "build:js": "esbuild ts/*.ts ts/**/index.ts ts/**/*.worker.ts --bundle --platform=browser --format=esm --minify --sourcemap --sources-content=false --outdir=min/js",
    "lint": "eslint . --cache --cache-location ./node_modules/.cache/eslint/ >eslint.log",
    "watch": "npm-run-all --parallel watch:**",
    "watch:css": "npm run build:css -- --watch",
    "watch:js": "npm run build:js -- --watch"
  },
  "devDependencies": {
    "@mephisto5558/eslint-config": "latest",
    "esbuild": "0.28.x",
    "npm-run-all2": "8.x",
    "sweetalert2": "^11.26.24"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": ">=20.11.0"
    }
  }
}
